# Copy to `.env` and fill in real values. `.env` is git-ignored.

# ---- Core ----
SITE_URL=https://sgslah.com
PORT=8085
WORKERS=2

# ---- HitPay (Singapore PSP with native PayNow) ----
# Get these from https://dashboard.hit-pay.com -> Settings -> API Keys
HITPAY_API_KEY=
HITPAY_SALT=
# Set to 1 for sandbox testing, leave empty/0 for live
HITPAY_SANDBOX=1

# ---- Feature flags ----
# Set to "false" to disable the entire Top Up section (routes, nav links, sitemap entries).
# All top-up code stays intact and can be re-enabled by flipping this to "true".
TOPUP_ENABLED=false

# ---- Top-up supplier ----
# Options: "moogold" (live), "mock" (dev), or leave empty to auto-detect
TOPUP_SUPPLIER=

# ---- MooGold reseller credentials ----
# Request from sales@moogold.com or WhatsApp +60 1156677135
MOOGOLD_PARTNER_ID=
MOOGOLD_SECRET_KEY=
MOOGOLD_AUTH_USER=
MOOGOLD_AUTH_PASS=
# MooGold's MLBB product_id (defaults to 1 if unset; confirm with MooGold support)
MOOGOLD_MLBB_PRODUCT_ID=1
MOOGOLD_SANDBOX=

# ---- SGS Telegram bot integration (verification portal) ----
# The /register page is reached via @SGS_MLBOT's login_url button. We verify
# the Telegram-signed payload (HMAC) using the bot's token, run the user
# through MLBB verification, then call the bot's internal webhook to unmute.

# Same token as ml_bot's BOT_TOKEN — get it from @BotFather. Used as the
# HMAC secret per https://core.telegram.org/widgets/login#checking-authorization
BOT_TOKEN=

# ml_bot's internal aiohttp webhook (bound to 127.0.0.1 on the VPS)
BOT_WEBHOOK_URL=http://127.0.0.1:8090/webhook/register

# Shared secret with ml_bot — must match WEBHOOK_SECRET on the bot side
WEBHOOK_SECRET=sgs_internal_secret_2026

# OpenMLBB API base. Override only if you're testing against a fork/mirror.
OPENMLBB_BASE=https://openmlbb.fastapicloud.dev
