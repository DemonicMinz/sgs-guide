r": "https://akmpicture.youngjoygame.com/dist/face/3523/71/70/20_new_94379027-a0bc-400c-afc0-9b0f7569095a.jpg", "historyRankLevel": 237, "level": 115, "module": "mlbb", "name": "You're my wonderwall", "registerCountry": "ph", "registerTime": 1529243187, "roleId": 242547071, "zoneId": 3523}}], "uin": "mlbb:3523:242547071", "updatedAt": 1760526763036, "user": {"avatar": "https://akmpicture.youngjoygame.com/dist/face/3523/71/70/20_new_94379027-a0bc-400c-afc0-9b0f7569095a.jpg", "historyRankLevel": 237, "level": 115, "module": "mlbb", "name": "You're my wonderwall", "roleId": 242547071, "zoneId": 3523}, "vote_all": {"average": 1, "count": 3, "target": "730483272659264", "total": 3, "user_count": 3, "vote": {"id": 2758890}}}, {"createdAt": 1729946532498, "data": {"channels": ["UGC", "recommend"], "data": {"cooperates": [{"cooperate_desc": "Apart from being helped by his CC skill, Martis can also kill enemies who are dying due to our damage. and martis is thick enough to survive, because baxia hero lacks cc.", "cooperate_hero_id": 58, "cooperate_rate": 100}], "counters": [{"counter_desc": "Because the Baxia we use is not a full tank, it is very beneficial to Wanwan and detrimental to our friends when we are often close to Wanwan because it can activate 3 Wanwan skills.\n\n", "counter_hero_id": 89, "counter_rate": 100}, {"counter_desc": "Because our baxia is not thick and the damage from skill 2 is not felt if it is not assisted with skill 3, then when the baxia is caught it will be a burden, instead of targeting weak enemy heroes we are the ones being targeted.\n\n", "counter_hero_id": 10, "counter_rate": 80}, {"counter_desc": "A hero with high mobility, Baxia will have difficulty targeting.\n\n", "counter_hero_id": 118, "counter_rate": 100}], "data_version": 1, "dominants": [{"dominant_desc": "Aim for enemies who can be killed first, provided the enemy doesn't use flicker and doesn't have anyone to support him. and of course you have to help friends. use skill 1 to hit and stun the enemy then use the execution spell to kill when they have little blood.\n\n", "dominant_title": "Early Game"}, {"dominant_desc": "Ready to open war and support friends, make sure skill 1 first then skill 3 when you want to hit the enemy.\n\n", "dominant_title": "Skill 3 Open"}, {"dominant_desc": "Play as you like, prioritize pushing, and support our damage dealer. but if me.. I like killing enemies.. haha.. I want to find satisfaction in playing. :V\n\n", "dominant_title": "Next until End"}], "emblems": [{"emblem_desc": "We don't play full tank or full damage, we play stealth and target enemy heroes from behind.\n\n", "emblem_gifts": [711, 1221, 631], "emblem_id": 20003, "emblem_title": "Baxia Room Killer"}], "equips": [{"equip_desc": "Cursed Helmet & Blade Armor is flexible and can be changed depending on who the enemy is.", "equip_ids": [2014, 2212, 3524, 3208, 3201, 2207], "equip_title": "Baxia Room Killer "}], "game_version": "1.9.21", "hero": {"hero_id": 87, "hero_lane": "3", "hero_overview": "Baxia relies on skills 1 and 3, so if you don't have the skills ready, just shadowing the enemy, don't go into war. and this can counter or target the main enemy hero such as mm, mage or jungle. and when you first play, prioritize targeting heroes who can be killed and the enemy heroes don't use flicker. Play Hit and Run!", "hero_strength": "Baxia has a passive to reduce the enemy's additional blood, and skill 3 is old so apart from doing damage it is also good for support, skill 2 is also very painful. one on one is not afraid of any hero. Except against heroes with high mobility.", "hero_tags": [1, 2, 11], "hero_weakness": "Baxia's weakness is against heroes with high mobility, and this is not a crowd control type of hero, because it is very inefficient, Baxia is good as an open war hero but by ensuring that the target is the enemy's main hero."}, "language": "en", "pages": ["hero", "spell", "emblem", "equip", "dominant", "cooperate"], "recommend": "Recommended for solo player! From Solo Player to The Global Player.", "snapshot": "https://akmweb.youngjoygame.com/web/academy/image/3538f3fbaf17665ed53a77af34f8f0f5.jpeg", "spell": {"spell_desc": "We focus on playing hit and run. And target heroes who are weak or don't have support from their friends.", "spell_id": 20150}, "title": "Baxia All Role + Killer"}, "state": "release", "type": "ugc_hero"}, "dynamic": {"views": 13, "views_by_4h_total_24h": 1, "votes": 1}, "form": {"id": 2737553}, "id": 728689315828160, "item_uin": [{"count": 1, "item": {"access": "all", "desc": "MLBB Academy Top Creators Reward", "icon": "https://akmweb.youngjoygame.com/web/gms/image/222cad2f3870af05c1e45b5a4f2eba03.png", "id": 2758031, "tags": ["badge", "2"], "title": "Creative Star", "usage": {"mode": "manual"}}, "uin": "mlbb:2157:81261788", "user": {"avatar": "https://akmpicture.youngjoygame.com/dist/face/2157/88/17/26_new_08ab4fbe-a6bd-493c-89d3-49e9ad56127e.jpg", "historyRankLevel": 244, "level": 143, "module": "mlbb", "name": "\u03b1\u03b7\u0442\u03b9\u043c\u03b5\u0442\u03b1", "registerCountry": "id", "registerTime": 1501161700, "roleId": 81261788, "zoneId": 2157}}], "uin": "mlbb:2157:81261788", "updatedAt": 1760267055096, "user": {"avatar": "https://akmpicture.youngjoygame.com/dist/face/2157/88/17/26_new_08ab4fbe-a6bd-493c-89d3-49e9ad56127e.jpg", "historyRankLevel": 244, "level": 143, "module": "mlbb", "name": "\u03b1\u03b7\u0442\u03b9\u043c\u03b5\u0442\u03b1", "roleId": 81261788, "zoneId": 2157}, "vote_all": {"average": 1, "count": 1, "target": "728689315828160", "total": 1, "user_count": 1, "vote": {"id": 2758890}}}], "total": 20}, "traceID": null}}