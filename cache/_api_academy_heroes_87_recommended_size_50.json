{"timestamp": 1776528370.1140807, "data": {"code": 0, "message": "OK", "data": {"records": [{"createdAt": 1775674543173, "data": {"channels": ["UGC", "recommend"], "data": {"cooperates": [{"cooperate_desc": "Angela gives the speed boost, additional healing and shield, and flexibility that a Baxia desperately needs.", "cooperate_hero_id": 55, "cooperate_rate": 100}, {"cooperate_desc": "The High Cut Strategy with Khaleed allows Baxia to rotate much faster and have a stronger presence due to how Khaleed essentially neutralizes Baxia's slow wave clear.", "cooperate_hero_id": 98, "cooperate_rate": 100}], "counters": [{"counter_desc": "Masha is the only hero that Baxia consistently struggles against. However, she is still beatable.", "counter_hero_id": 88, "counter_rate": 40}, {"counter_desc": "Everything about Baxia counters Thamuz. From the anti-heal, to the damage reduction. Thamuz is pretty much rendered useless against a Baxia. Baxia dominates him in both team-fights and 1v1s.", "counter_hero_id": 72, "counter_rate": 100}, {"counter_desc": "Yu Zhong is a similar case to Thamuz but has it slightly better due to generally having better micro. Baxia is still a very strong counter to Yu Zhong however.", "counter_hero_id": 95, "counter_rate": 80}, {"counter_desc": "Phoveus just evaporates against a Baxia. His inherent lack of mobility kills him.", "counter_hero_id": 106, "counter_rate": 100}], "data_version": 1, "dominants": [{"dominant_desc": "Baxia dominates most EXP Lane matchups. He is pretty much always ahead in Turtle 1 if the user plays him correctly. Use your 2nd skill sparingly, make sure to not miss as much as possible. It is your only choke point.", "dominant_title": "Early Game"}, {"dominant_desc": "By this phase, you now have the capability to burst most heroes (without Tough Boots) with your 1st skill + Petrify combo. Your sustain also increases dramatically.", "dominant_title": "Concentrated Energy Bought"}, {"dominant_desc": "The amount of defense this item gives is very good for Baxia. This is considered a major powerspike due to how much tankier Baxia gets after this item is bought and fully stacked.", "dominant_title": "Clock of Destiny Bought"}, {"dominant_desc": "By this point, Baxia has reached nigh-unbeatable status in 1v1 due to just how much damage his skills deal when the scaling is taken into account.", "dominant_title": "Replace Molten Essence with Holy Crystal"}], "emblems": [{"emblem_desc": "This emblem set-up gives a high amount of Spell Vamp, and also aids in wave clear with the help of Concussive Blast.", "emblem_gifts": [111, 721, 331], "emblem_id": 20007, "emblem_title": "The Sustain Triad"}], "equips": [{"equip_desc": "For a more comprehensive and detailed guide on why, please check out this video of mine:\n\nhttps://vt.tiktok.com/ZSHu1PkN5/", "equip_ids": [3103, 2202, 3111, 3113, 2112, 2208], "equip_title": "Cyphus Baxia EXP Sustain Build"}], "game_version": "2.1.18", "hero": {"hero_id": 87, "hero_lane": "1", "hero_overview": "This iteration of Baxia is a hybrid between Lapu-lapu and Yu Zhong. Baxia has the strongest laning ability in the entire game and is able to beat out every EXP Laner. He also effectively counters current meta-favorites in the EXP Lane like Yu Zhong, Alice, and Uranus.", "hero_strength": "This iteration of Baxia is pretty much able to 1v1 every hero in the entire game and reliably win. With his 1st skill + Petrify combo, it almost always guarantees a kill or a Purify/Flicker proc. This Baxia has the incredible zoning capabilities of a Yu Zhong and Lapu-lapu without the weakness of being horrible against Marksmen.\n\nFUN FACT: Baxia, despite being a Tank, has absurd damage scaling, as he also possesses the highest scaling skill in the entire game, his ultimate \"Tortoise's Puissance\" with 5,600 + (3,360% Total Magic Power) Magic Damage at max.", "hero_tags": [1, 7, 9], "hero_weakness": "Baxia is a hero that has always been riddled by his slow wave clearing. This Baxia is no different. Build Molten Essence to circumvent this issue."}, "language": "en", "pages": ["hero", "emblem", "equip", "dominant", "cooperate", "spell"], "recommend": "BAXIA MAGIC SUSTAIN BUILD \u2014 This build is very niche, yet extremely effective. This iteration of Baxia fills all of your EXP needs plus a bit extra.", "snapshot": "https://akmweb.youngjoygame.com/web/academy/image/0f54bc8e8bdf3e693d1cea36567edcfe.jpeg", "spell": {"spell_desc": "This spell allows Baxia to make crucial set-ups while also being able to almost always guarantee a kill when combined with his 1st skill.", "spell_id": 20070}, "title": "EXP Lane Baxia Sustain Set-up \u2014 by Cyphus"}, "state": "release", "type": "ugc_hero"}, "dynamic": {"hot": 54.7, "views": 4, "views_by_4h_total_24h": 1, "votes": 2}, "form": {"id": 2737553}, "id": 1103293179274368, "uin": "mlbb:3872:415954314", "updatedAt": 1775675692773, "user": {"avatar": "https://akmpicture.youngjoygame.com/dist/face/3872/14/43/46_new_7defeeb8-5485-46a7-8a59-948871bc5603.jpg", "historyRankLevel": 277, "level": 127, "module": "mlbb", "name": "Cyphus", "roleId": 415954314, "zoneId": 3872}, "vote_all": {"average": 1, "count": 2, "target": "1103293179274368", "total": 2, "user_count": 2, "vote": {"id": 2758890}}}, {"createdAt": 1770478058344, "data": {"channels": ["UGC", "recommend"], "data": {"cooperates": [{"cooperate_desc": "Early invade ", "cooperate_hero_id": 17, "cooperate_rate": 100}], "counters": [{"counter_desc": "U no shield u ded", "counter_hero_id": 81, "counter_rate": 80}], "data_version": 1, "dominants": [{"dominant_desc": "Invade", "dominant_title": "Early "}, {"dominant_desc": "Clear bush", "dominant_title": "Mid game"}, {"dominant_desc": "Ignore your mm and mage and kill enemies ", "dominant_title": "Late game "}], "emblems": [{"emblem_desc": "You are a tank. Be like one\n", "emblem_gifts": [711, 321, 331], "emblem_id": 20003, "emblem_title": "Soak up damage"}], "equips": [{"equip_desc": "Defence so good u ain't felling not